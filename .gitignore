# ============================================================
# .gitignore — Python + IDE + OS + project-specific
# ============================================================

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
env/
*.egg
*.so

# Environment
.env
.env.local
.env.*.local

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs & temp
*.log
*.tmp
*.temp

# Claude Code (local settings only)
.claude/settings.local.json
