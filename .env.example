# 环境变量配置文件
# 复制此文件为 .env 并填入你的API密钥

# ==================== 模型提供商配置 ====================
# 设置要使用的模型提供商（必填）
# 可选值：openai, azure, deepseek, zhipu, moonshot, ollama, custom
LLM_PROVIDER=openai

# ==================== OpenAI 配置 ====================
# OpenAI API密钥
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI API基础URL（可选，用于代理）
# OPENAI_API_BASE=https://api.openai.com/v1

# OpenAI模型名称（可选，默认gpt-4）
OPENAI_MODEL_NAME=gpt-4

# ==================== Azure OpenAI 配置 ====================
# Azure OpenAI API密钥
# AZURE_OPENAI_API_KEY=your-azure-api-key

# Azure OpenAI终端点
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure部署名称
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4-deployment

# ==================== DeepSeek 配置 ====================
# DeepSeek API密钥
# DEEPSEEK_API_KEY=your-deepseek-api-key

# DeepSeek模型名称（可选，默认deepseek-chat）
# DEEPSEEK_MODEL_NAME=deepseek-chat

# ==================== 智谱AI 配置 ====================
# 智谱AI API密钥
# ZHIPU_API_KEY=your-zhipu-api-key

# 智谱模型名称（可选，默认glm-4）
# ZHIPU_MODEL_NAME=glm-4

# ==================== Moonshot (Kimi) 配置 ====================
# Moonshot API密钥
# MOONSHOT_API_KEY=your-moonshot-api-key

# Moonshot模型名称（可选，默认moonshot-v1-8k）
# MOONSHOT_MODEL_NAME=moonshot-v1-8k

# ==================== Ollama (本地模型) 配置 ====================
# Ollama服务地址
# OLLAMA_BASE_URL=http://localhost:11434

# Ollama模型名称
# OLLAMA_MODEL_NAME=llama2

# ==================== 自定义API配置 ====================
# 自定义API密钥（用于兼容OpenAI格式的API）
# CUSTOM_API_KEY=your-custom-api-key

# 自定义API基础URL
# CUSTOM_API_BASE=https://your-custom-api.com/v1

# 自定义模型名称
# CUSTOM_MODEL_NAME=your-model-name

# ==================== 通用配置 ====================
# 通用模型名称（覆盖提供商默认值）
# MODEL_NAME=

# 模型温度参数（0-1）
MODEL_TEMPERATURE=0.7

# 最大token数
MAX_TOKENS=4096

# ==================== 安全配置 ====================
# 应用 API Key（留空则跳过认证，开发模式）
# APP_API_KEY=your-app-api-key

# CORS 允许的域名（逗号分隔，* 表示全部）
# CORS_ALLOWED_ORIGINS=https://myapp.com,https://admin.myapp.com

# 速率限制
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_GLOBAL=60/minute
# RATE_LIMIT_CHAT=10/minute
# RATE_LIMIT_STREAM=5/minute

# 最大消息长度（字符数）
# MAX_MESSAGE_LENGTH=10000

# ==================== Docker 配置 ====================
# 应用端口
# APP_PORT=8000
# Redis 端口
# REDIS_PORT=6379
# 开发模式端口
# DEV_PORT=8080

# 运行环境 (development / production)
# ENV=production

# ==================== 其他工具配置 ====================
# 搜索API密钥（可选）
SEARCH_API_KEY=